									"const json = pm.response.json();",
									"if (json.accessToken) {",
									"  pm.collectionVariables.set('clienteToken', json.accessToken);",
									"  pm.collectionVariables.set('clienteId', json.usuario.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"cliente@empresa.com\",\n  \"password\": \"123456\"\n}"
