						},
						"description": "Confirma primeiro codigo TOTP e ativa MFA. Substituir codigo pelo gerado no app autenticador."
					}
				},
				{
					"name": "POST /auth/totp/verify — 200",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"if (json.usuario?.role === 'ADMIN') { pm.collectionVariables.set('adminToken', json.accessToken); pm.collectionVariables.set('adminRefreshToken', json.refreshToken); pm.collectionVariables.set('adminId', json.usuario.id); }",
									"if (json.usuario?.role === 'CLIENTE') { pm.collectionVariables.set('clienteToken', json.accessToken); pm.collectionVariables.set('clienteRefreshToken', json.refreshToken); pm.collectionVariables.set('clienteId', json.usuario.id); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/totp/verify",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"totp",
								"verify"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mfaChallengeId\": \"{{mfaChallengeId}}\",\n  \"codigo\": \"123456\"\n}"
						},
						"description": "Conclui login com mfaChallengeId retornado por /auth/login. Salva tokens conforme usuario retornado."
					}
				},
				{
					"name": "POST /auth/totp/disable (admin) — 204",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							},
							{
								"key": "X-Step-Up-Token",
								"value": "{{stepUpToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/totp/disable",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"totp",
								"disable"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"passwordAtual\": \"senha-passphrase-segura\"\n}"
						},
						"description": "Desabilita TOTP. Exige senha atual e X-Step-Up-Token valido."
					}
				}
			]
		},
