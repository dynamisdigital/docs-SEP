		{
			"name": "Usuários",
			"description": "Recursos de usuario. Cadastro publico cria sempre CLIENTE; criacao de ADMIN fica em /api/v1/admin/usuarios com token ADMIN.",
			"item": [
				{
					"name": "POST /usuarios (criar cliente publico) — 201",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"const json = pm.response.json();",
									"if (json.id) pm.collectionVariables.set('clienteId', json.id);",
									"pm.test('senha nao exposta', () => pm.expect(json).to.not.have.property('password'));",
									"pm.test('role CLIENTE', () => pm.expect(json.role).to.eql('CLIENTE'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/usuarios",
							"host": [
